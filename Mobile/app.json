{
  "expo": {
    "name": "Simulador Financeiro",
    "slug": "simulador-financeiro",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "ios": {
      "bundleIdentifier": "com.guts26.simuladorfinanceiro",
      "supportsTablet": true
    },
    "android": {
      "package": "com.guts26.simuladorfinanceiro",
      "jsEngine": "hermes",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png"
      }
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "enableProguardInReleaseBuilds": true,
            "enableMinifyInReleaseBuilds": true
          }
        }
      ]
    ],
    "owner": "guts26",
    "extra": {
      "eas": {
        "projectId": "4006c4ae-18d4-492e-ae76-9e404d593821"
      }
    }
  }
}
